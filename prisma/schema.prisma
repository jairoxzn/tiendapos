// =============================================
// TiendaPOS - Prisma Schema
// =============================================
// Modelos completos para sistema POS de tienda de ropa.
// Neon PostgreSQL + Prisma Client.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================
// ENUMS
// =============================================

enum Role {
  ADMIN
  CASHIER
}

enum MovementType {
  IN          // Entrada (compra, ajuste +)
  OUT         // Salida (venta, ajuste -)
  ADJUSTMENT  // Ajuste manual
  RETURN      // Devolución
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH        // Efectivo
  YAPE
  PLIN
  CARD        // Tarjeta
  TRANSFER    // Transferencia
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

// =============================================
// USER & AUTH
// =============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          Role      @default(CASHIER)
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sales              Sale[]
  cashRegisters      CashRegister[]
  inventoryMovements InventoryMovement[]

  @@index([email])
  @@index([role])
}

// =============================================
// CATALOG
// =============================================

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@index([slug])
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logoUrl     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@index([slug])
}

model Product {
  id            String     @id @default(cuid())
  sku           String     @unique
  name          String
  description   String?
  imageUrl      String?
  images        String[]   @default([])
  costPrice     Decimal    @db.Decimal(10, 2)
  salePrice     Decimal    @db.Decimal(10, 2)
  hasVariants   Boolean    @default(true)
  minStock      Int        @default(5)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  categoryId    String
  category      Category   @relation(fields: [categoryId], references: [id])

  brandId       String?
  brand         Brand?     @relation(fields: [brandId], references: [id])

  variants      Variant[]

  @@index([sku])
  @@index([name])
  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
}

// Variants represent size + color combinations of a product.
// e.g. "Polo Oversize" -> M/Negro, M/Blanco, L/Negro, L/Blanco
model Variant {
  id          String   @id @default(cuid())
  sku         String   @unique           // SKU específico de la variante (ej: POLO-001-M-NEG)
  size        String                      // "S", "M", "L", "XL", "28", "30", etc.
  color       String                      // "Negro", "Blanco", "Rosa", etc.
  colorHex    String?                     // Hex opcional para preview UI
  barcode     String?  @unique            // Código de barras / QR
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  saleDetails        SaleDetail[]
  inventoryMovements InventoryMovement[]

  @@unique([productId, size, color])
  @@index([sku])
  @@index([barcode])
  @@index([productId])
}

// =============================================
// INVENTORY (Kardex)
// =============================================

model InventoryMovement {
  id          String        @id @default(cuid())
  type        MovementType
  quantity    Int                                 // siempre positivo; el `type` define si suma o resta
  stockBefore Int                                 // snapshot del stock antes del movimiento
  stockAfter  Int                                 // snapshot del stock después
  unitCost    Decimal?      @db.Decimal(10, 2)    // costo unitario (entradas)
  reason      String?                             // motivo en ajustes/devoluciones
  reference   String?                             // # de factura/guía/sale id de referencia
  createdAt   DateTime      @default(now())

  variantId   String
  variant     Variant       @relation(fields: [variantId], references: [id])

  userId      String
  user        User          @relation(fields: [userId], references: [id])

  saleId      String?
  sale        Sale?         @relation(fields: [saleId], references: [id])

  @@index([variantId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// =============================================
// CUSTOMERS
// =============================================

model Customer {
  id            String    @id @default(cuid())
  docType       String    @default("DNI")  // DNI, RUC, CE, PASSPORT
  docNumber     String    @unique
  firstName     String
  lastName      String?
  email         String?
  phone         String?
  address       String?
  birthDate     DateTime?
  loyaltyPoints Int       @default(0)
  notes         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sales         Sale[]

  @@index([docNumber])
  @@index([firstName, lastName])
}

// =============================================
// SALES (POS)
// =============================================

model Sale {
  id              String       @id @default(cuid())
  code            String       @unique           // BOL-000001
  status          SaleStatus   @default(COMPLETED)

  subtotal        Decimal      @db.Decimal(12, 2)
  discountAmount  Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal      @db.Decimal(12, 2) // IGV
  total           Decimal      @db.Decimal(12, 2)

  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  userId          String
  user            User         @relation(fields: [userId], references: [id])

  customerId      String?
  customer        Customer?    @relation(fields: [customerId], references: [id])

  cashRegisterId  String?
  cashRegister    CashRegister? @relation(fields: [cashRegisterId], references: [id])

  details            SaleDetail[]
  payments           Payment[]
  inventoryMovements InventoryMovement[]

  @@index([code])
  @@index([userId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model SaleDetail {
  id          String   @id @default(cuid())
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(12, 2)

  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  variantId   String
  variant     Variant  @relation(fields: [variantId], references: [id])

  // Snapshot del producto en el momento de la venta (por si cambia luego)
  productName String
  variantInfo String  // "Talla M / Negro"

  @@index([saleId])
  @@index([variantId])
}

model Payment {
  id          String         @id @default(cuid())
  method      PaymentMethod
  amount      Decimal        @db.Decimal(12, 2)
  reference   String?        // # operación Yape/Plin/Tarjeta
  createdAt   DateTime       @default(now())

  saleId      String
  sale        Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method])
}

// =============================================
// CASH REGISTER (Caja diaria)
// =============================================

model CashRegister {
  id              String              @id @default(cuid())
  code            String              @unique          // CAJA-2026-05-13-001
  status          CashRegisterStatus  @default(OPEN)
  openingAmount   Decimal             @db.Decimal(12, 2)
  closingAmount   Decimal?            @db.Decimal(12, 2)
  expectedAmount  Decimal?            @db.Decimal(12, 2)
  difference      Decimal?            @db.Decimal(12, 2)
  notes           String?
  openedAt        DateTime            @default(now())
  closedAt        DateTime?

  userId          String
  user            User                @relation(fields: [userId], references: [id])

  sales           Sale[]

  @@index([userId])
  @@index([status])
  @@index([openedAt])
}
