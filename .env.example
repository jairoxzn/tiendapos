# =============================================
# TiendaPOS - Environment Variables
# =============================================
# Copia este archivo a `.env` y rellena los valores.
# NUNCA subas `.env` al repositorio.

# ---------- Database (Neon PostgreSQL) ----------
# Cómo obtenerla:
#   1. Crea un proyecto en https://console.neon.tech
#   2. Copia la "Pooled connection" para DATABASE_URL (la usa Prisma en runtime)
#   3. Copia la "Direct connection" para DIRECT_URL (la usa Prisma para migraciones)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# ---------- Auth ----------
# Genera uno con: `openssl rand -base64 48`  o  `node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"`
JWT_SECRET="cambia-esto-en-produccion-por-un-string-largo-y-aleatorio"
SESSION_COOKIE_NAME="tiendapos_session"
SESSION_MAX_AGE_DAYS="7"

# ---------- App ----------
NEXT_PUBLIC_APP_NAME="TiendaPOS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- Imágenes ----------
# Esta versión usa URLs externas (Instagram, Google Drive con link público, etc.)
# Hosts permitidos en next.config.mjs > images.remotePatterns.

# ---------- Empresa (para boletas/tickets) ----------
NEXT_PUBLIC_EMPRESA_NOMBRE="Mi Tienda de Ropa"
NEXT_PUBLIC_EMPRESA_RUC="20000000001"
NEXT_PUBLIC_EMPRESA_DIRECCION="Av. Ejemplo 123, Lima"
NEXT_PUBLIC_EMPRESA_TELEFONO="+51 999 999 999"
NEXT_PUBLIC_IGV_PERCENT="18"
